# You can use this file to easily send requests to your API.
# Prerequisite: humao.rest-client Vscode plugin (already present on codespace)
# High-level overview of REST API concepts used here: https://www.packtpub.com/en-us/learning/how-to-tutorials/what-are-rest-verbs-and-status-codes-tutorial

# TIP: Run requests in order - later requests reference IDs from earlier responses


# ==========================================
# User Controller Endpoints
# ==========================================

### Get all users
GET http://localhost:8080/api/users

### Create a new user (run this to populate variables for other requests)
# @name createUser
POST http://localhost:8080/api/users
Content-Type: application/json

{
    "name": "Jean Valjean",
    "email": "prisoner24601@france.fr",
    "password": "password",
    "role": "user"
}

### Get user by ID (uses ID from createUser response)
GET http://localhost:8080/api/users/{{createUser.response.body.id}}

### Get user by email (uses email from createUser response)
GET http://localhost:8080/api/users/by-email?email={{createUser.response.body.email}}

### Update user name (PUT)
PUT http://localhost:8080/api/users/{{createUser.response.body.id}}
Content-Type: application/json

{
    "name": "Monsieur Madeleine"
}

### Change user name (PATCH)
PATCH http://localhost:8080/api/users/{{createUser.response.body.id}}/name
Content-Type: application/json

{
    "name": "Monsieur le Maire"
}


# ==========================================
# Todo Controller Endpoints
# ==========================================

### Create a new todo (run this after createUser to populate variables)
# @name createTodo
POST http://localhost:8080/api/todos
Content-Type: application/json

{
    "description": "Rescue Cosette from the Thénardiers",
    "assigneeEmail": "{{createUser.response.body.email}}"
}

### Get todos by assignee email
GET http://localhost:8080/api/todos?assigneeEmail={{createUser.response.body.email}}

### Get todo by ID (uses ID from createTodo response)
GET http://localhost:8080/api/todos/{{createTodo.response.body.id}}

### Mark todo as done
PATCH http://localhost:8080/api/todos/{{createTodo.response.body.id}}/done
Content-Type: application/json

true

### Assign todo to another user
# Note: You'll need another user to exist for this to work
PATCH http://localhost:8080/api/todos/{{createTodo.response.body.id}}/assignee
Content-Type: application/json

{
    "newAssigneeEmail": "frodo@theshire.me"
}

### Edit todo description
PATCH http://localhost:8080/api/todos/{{createTodo.response.body.id}}/description
Content-Type: application/json

{
    "description": "Escape from Inspector Javert"
}


# ==========================================
# Cleanup (run these last)
# ==========================================

### Delete todo
DELETE http://localhost:8080/api/todos/{{createTodo.response.body.id}}

### Delete user
DELETE http://localhost:8080/api/users/{{createUser.response.body.id}}



### Login for Telu Mihai (Token)
# @name loginMihai
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
    "email": "mihait@gmail.com",
    "password": "password"
}

# ==========================================
# FLOW COMPLET: Echipe, Membri și Foldere
# ==========================================

### 1. Creare User ADMIN
# @name createAdmin
POST http://localhost:8080/api/users
Content-Type: application/json

{
    "name": "Sefu la Echipa",
    "email": "admin.echipa@prodeng.ro",
    "password": "password",
    "role": "admin"
}

### 2. Login ADMIN (pentru a obține Token-ul)
# @name loginAdmin
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
    "email": "admin.echipa@prodeng.ro",
    "password": "password"
}

### 3. Adminul creează o Echipă
# @name createTeam
POST http://localhost:8080/api/teams
Authorization: Bearer {{loginAdmin.response.body.token}}
Content-Type: application/json

{
    "name": "Echipa Backend",
    "description": "Responsabili cu Spring Boot si MongoDB"
}

### 4. Creare User SIMPLU (viitor membru)
# @name createMember
POST http://localhost:8080/api/users
Content-Type: application/json

{
    "name": "Dev Junior",
    "email": "junior@prodeng.ro",
    "password": "password",
    "role": "user"
}

### 5. Login User SIMPLU
# @name loginMember
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
    "email": "junior@prodeng.ro",
    "password": "password"
}

### 6. Userul Simplu cere să intre în Echipă
# @name joinRequest
POST http://localhost:8080/api/teams/{{createTeam.response.body.id}}/join-requests
Authorization: Bearer {{loginMember.response.body.token}}

### 7. Adminul vede cererile în așteptare
GET http://localhost:8080/api/teams/{{createTeam.response.body.id}}/join-requests
Authorization: Bearer {{loginAdmin.response.body.token}}

### 8. Adminul Aprobă cererea userului
POST http://localhost:8080/api/teams/{{createTeam.response.body.id}}/join-requests/{{createMember.response.body.id}}/approve
Authorization: Bearer {{loginAdmin.response.body.token}}

### 9. Adminul creează un FOLDER PRINCIPAL (Root Folder) în echipă
# @name createRootFolder
POST http://localhost:8080/api/folders/{{createTeam.response.body.id}}
Authorization: Bearer {{loginAdmin.response.body.token}}
Content-Type: application/json

{
    "name": "Documentație Proiect",
    "parentFolderId": null
}

### 10. Adminul creează un SUBFOLDER în folderul principal
# @name createSubFolder
POST http://localhost:8080/api/folders/{{createTeam.response.body.id}}
Authorization: Bearer {{loginAdmin.response.body.token}}
Content-Type: application/json

{
    "name": "Schițe și Diagrame",
    "parentFolderId": "{{createRootFolder.response.body.id}}"
}

### 11. Userul simplu (acum membru) vede toate folderele echipei
GET http://localhost:8080/api/folders/{{createTeam.response.body.id}}
Authorization: Bearer {{loginMember.response.body.token}}

### 12. Modificarea numelui unui folder (PATCH)
PATCH http://localhost:8080/api/folders/{{createTeam.response.body.id}}/{{createRootFolder.response.body.id}}/name
Authorization: Bearer {{loginAdmin.response.body.token}}
Content-Type: text/plain

